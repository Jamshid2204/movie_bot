# ===== Telegram =====
# Bot token from @BotFather
BOT_TOKEN=

# Storage channel = private channel where movie files live (forwarded to users from here)
STORAGE_CHANNEL_ID=

# Required channels users MUST join before the bot works.
# Any of these per item, comma-separated:
#   @username                 (public channel)
#   username                  (public, no @)
#   -1001234567890            (numeric chat id)
#   <id-or-username>:<url>    (target + explicit invite URL)
REQUIRED_CHANNELS=

# Comma-separated Telegram user IDs allowed to run admin commands (e.g. /stats, /delete)
ADMIN_IDS=

# Movies per page in the inline keyboard lists
MOVIES_PER_PAGE=8

# ===== Supabase (see ../SUPABASE_SETUP.md) =====
SUPABASE_URL=
# Server-only. Bypasses RLS. NEVER ship to a browser/dashboard.
SUPABASE_SERVICE_ROLE_KEY=
